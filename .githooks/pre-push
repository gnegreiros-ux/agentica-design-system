#!/bin/sh
# Pre-push hook — Playwright snapshot update reminder (ADR-066)
#
# Detects whether files in components/ or tokens/ changed since
# the last push and shows a reminder if so.
#
# Enable with: git config core.hooksPath .githooks

REMOTE="$1"
URL="$2"

# Files changed since the last commit pushed on the current branch
CHANGED=$(git diff --name-only HEAD~1 HEAD 2>/dev/null)

COMPONENTS_CHANGED=$(echo "$CHANGED" | grep -E '^(components|tokens)/' | head -1)

if [ -n "$COMPONENTS_CHANGED" ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  ⚠️   Reminder — Playwright snapshots                    ║"
  echo "╠══════════════════════════════════════════════════════════╣"
  echo "║  Files in components/ or tokens/ have changed.           ║"
  echo "║                                                          ║"
  echo "║  If the change is intentional, remember to verify        ║"
  echo "║  that Playwright visual tests still pass:                ║"
  echo "║                                                          ║"
  echo "║    node site/build.js                                    ║"
  echo "║    npx playwright test --project=chromium                ║"
  echo "║                                                          ║"
  echo "║  If snapshots need updating:                             ║"
  echo "║    npx playwright test --update-snapshots                ║"
  echo "║    git add tests/visual/snapshots/                       ║"
  echo "║    git commit -m 'test(visual): update snapshots'        ║"
  echo "║                                                          ║"
  echo "║  ADR-066 — the last word is always human.                ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo ""
fi

exit 0
