{
  "name": "agentica-design-system",
  "version": "0.1.0",
  "description": "Agentica — Agentic design system",
  "license": "MIT",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "site"
  ],
  "scripts": {
    "tokens": "node style-dictionary/build.cjs && node packages/tokens/build.js",
    "tokens:watch": "nodemon --watch tokens/ --ext json --exec 'node style-dictionary/build.cjs'",
    "build:components-package": "node packages/components/build.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "storybook": "npm run tokens && storybook dev -p 6006",
    "build-storybook": "npm run tokens && storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "lang-audit": "node scripts/audit-language.js",
    "axe": "node scripts/axe-audit.js",
    "axe:mobile": "node scripts/axe-audit.js --mobile",
    "axe:dark": "node scripts/axe-audit.js --dark",
    "axe:all": "node scripts/axe-audit.js",
    "playwright": "npx playwright test",
    "playwright:update": "npx playwright test --update-snapshots",
    "playwright:report": "npx playwright show-report",
    "smoke": "node scripts/smoke-test.js",
    "relationships": "node scripts/extract-relationships.js --fix-report",
    "validate:contracts": "node scripts/validate-contracts.js",
    "test": "npm run smoke && npm run lang-audit && npm run validate:contracts && npm run axe:all"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@changesets/cli": "^2.27.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@playwright/test": "^1.61.1",
    "@radix-ui/colors": "^3.0.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/web-components-vite": "^10.4.1",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "lit": "^3.0.0",
    "playwright": "^1.60.0",
    "storybook": "^10.4.1",
    "style-dictionary": "^3.9.2",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "lucide": "^1.17.0"
  }
}
