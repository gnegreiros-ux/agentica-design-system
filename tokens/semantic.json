      },
      "raised": {
        "$value": "0 4px 16px rgba(0,0,0,0.10)",
        "$type": "other",
        "$intent": "Ombre d'élément surélevé — menus déroulants, nav mobile (ADR-046)"
      },
      "card-hover": {
        "$value": "0 4px 16px rgba(13,116,206,0.10)",
        "$type": "other",
        "$intent": "Ombre de survol de carte — lift teinté marque (action.primary, ADR-046)"
      },
      "card": {
        "$value": "0 1px 3px rgba(0,0,0,0.10), 0 1px 2px rgba(0,0,0,0.06)",
        "$type": "other",
        "$intent": "Ombre de carte au repos — élévation légère. Solde le résidu d'ADR-046 (consommée par component.card.elevated). Voir ADR-049."
      }
    },
    "space": {
      "density": {
        "_readme": {
          "$value": "Trois groupes explicites (compact/normal/comfortable). compact utilise floor(), comfortable utilise ceil(), tous deux divisés par primitive.density.grid-unit (4) pour garantir l'alignement 4px. Technique : Sam's math equations in Tokens Studio. Voir ADR-025.",
          "$type": "other"
        },
        "factor": {
          "compact": {
            "$value": "{primitive.density.factor.compact}",
            "$type": "number",
            "$intent": "0.75 — scaling vers le bas, floor() pour alignement grille"
          },
          "normal": {
            "$value": "{primitive.density.factor.normal}",
            "$type": "number",
            "$intent": "1.0 — pas de calcul, valeurs primitives directes"
          },
          "comfortable": {
            "$value": "{primitive.density.factor.comfortable}",
            "$type": "number",
            "$intent": "1.25 — scaling vers le haut, ceil() pour alignement grille"
          }
        }
      },
      "control": {
        "padding-x": {
          "$value": "{primitive.space.4}",
          "$type": "dimension",
          "$intent": "16px — Espacement horizontal des contrôles (densité normale). Voir space.compact ou space.comfortable pour les autres densités."
        },
        "padding-y": {
          "$value": "{primitive.space.2}",
          "$type": "dimension",
          "$intent": "8px — Espacement vertical des contrôles (densité normale)."
        },
        "gap": {
          "$value": "{primitive.space.2}",
          "$type": "dimension",
          "$intent": "8px — Écart interne entre éléments d'un contrôle (densité normale)."
        }
      },
      "layout": {
        "section": {
          "$value": "{primitive.space.8}",
          "$type": "dimension",
          "$intent": "32px — Espacement entre sections de page (densité normale)."
        },
        "component": {
          "$value": "{primitive.space.5}",
          "$type": "dimension",
          "$intent": "20px — Espacement entre composants (densité normale)."
        },
        "page-gutter": {
          "$value": "{primitive.space.20}",
          "$type": "dimension",
          "$intent": "80px — Gouttière horizontale des sections de page documentation (layout 1440px). Voir ADR-052."
        }
      },
      "compact": {
        "_readme": {
          "$value": "Densité compacte — floor(valeur × 0.75 / 4) × 4. Toutes les valeurs sont des multiples de 4px. Usage : dashboards, tableaux, outils data-dense.",
          "$type": "other"
        },
        "control": {
          "padding-x": {
            "$value": "floor({primitive.space.4} * {semantic.space.density.factor.compact} / {primitive.density.grid-unit}) * {primitive.density.grid-unit}",
            "$type": "dimension",
            "$intent": "12px — padding-x compact (16 × 0.75 = 12, déjà sur grille)"
          },
          "padding-y": {
            "$value": "floor({primitive.space.2} * {semantic.space.density.factor.compact} / {primitive.density.grid-unit}) * {primitive.density.grid-unit}",
            "$type": "dimension",
            "$intent": "4px — padding-y compact (8 × 0.75 = 6 → floor(6/4)×4 = 4px)"
          },
          "gap": {
            "$value": "floor({primitive.space.2} * {semantic.space.density.factor.compact} / {primitive.density.grid-unit}) * {primitive.density.grid-unit}",
            "$type": "dimension",
            "$intent": "4px — gap compact"
          }
        },
        "layout": {
          "section": {
            "$value": "floor({primitive.space.8} * {semantic.space.density.factor.compact} / {primitive.density.grid-unit}) * {primitive.density.grid-unit}",
            "$type": "dimension",
            "$intent": "24px — section compact (32 × 0.75 = 24, déjà sur grille)"
          },
          "component": {
            "$value": "floor({primitive.space.5} * {semantic.space.density.factor.compact} / {primitive.density.grid-unit}) * {primitive.density.grid-unit}",
            "$type": "dimension",
            "$intent": "12px — component compact (20 × 0.75 = 15 → floor(15/4)×4 = 12px)"
          }
        }
      },
      "comfortable": {
        "_readme": {
          "$value": "Densité confortable — ceil(valeur × 1.25 / 4) × 4. Toutes les valeurs sont des multiples de 4px. Usage : marketing, onboarding, pages de lecture.",
          "$type": "other"
        },
        "control": {
          "padding-x": {
            "$value": "ceil({primitive.space.4} * {semantic.space.density.factor.comfortable} / {primitive.density.grid-unit}) * {primitive.density.grid-unit}",
            "$type": "dimension",
            "$intent": "20px — padding-x comfortable (16 × 1.25 = 20, déjà sur grille)"
          },
          "padding-y": {
            "$value": "ceil({primitive.space.2} * {semantic.space.density.factor.comfortable} / {primitive.density.grid-unit}) * {primitive.density.grid-unit}",
            "$type": "dimension",
            "$intent": "12px — padding-y comfortable (8 × 1.25 = 10 → ceil(10/4)×4 = 12px)"
          },
          "gap": {
            "$value": "ceil({primitive.space.2} * {semantic.space.density.factor.comfortable} / {primitive.density.grid-unit}) * {primitive.density.grid-unit}",
            "$type": "dimension",
            "$intent": "12px — gap comfortable"
          }
        },
        "layout": {
          "section": {
            "$value": "ceil({primitive.space.8} * {semantic.space.density.factor.comfortable} / {primitive.density.grid-unit}) * {primitive.density.grid-unit}",
            "$type": "dimension",
            "$intent": "40px — section comfortable (32 × 1.25 = 40, déjà sur grille)"
          },
          "component": {
            "$value": "ceil({primitive.space.5} * {semantic.space.density.factor.comfortable} / {primitive.density.grid-unit}) * {primitive.density.grid-unit}",
            "$type": "dimension",
            "$intent": "28px — component comfortable (20 × 1.25 = 25 → ceil(25/4)×4 = 28px)"
          }
        }
      }
