{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "level": "semantic",
    "description": "Traduction des primitives en langage métier. Encode l'INTENTION, pas la valeur. Lisible par les humains et les agents IA.",
    "version": "1.0.0",
    "rule": "Les agents comprennent la FONCTION, pas la valeur. color.feedback.danger est une intention. red-700 est une valeur décorative."
  },
  "semantic": {
    "color": {
      "action": {
        "primary":          { "value": "{primitive.color.blue.11}",  "$type": "color", "$intent": "Action principale — CTA, bouton primaire" },
        "primary-hover":    { "value": "{primitive.color.blue.12}",  "$type": "color", "$intent": "État survol de l'action principale" },
        "primary-disabled": { "value": "{primitive.color.gray.6}",   "$type": "color", "$intent": "Action principale désactivée — fond bouton inactif (WCAG 1.4.3 exempt)" }
      },
      "feedback": {
        "danger":        { "value": "{primitive.color.red.11}",   "$type": "color", "$intent": "Erreur, action destructrice, alerte critique" },
        "danger-subtle": { "value": "{primitive.color.red.3}",    "$type": "color", "$intent": "Fond subtil pour état danger" },
        "success":       { "value": "{primitive.color.green.11}", "$type": "color", "$intent": "Confirmation, succès, validation" },
        "info":          { "value": "{primitive.color.blue.11}",  "$type": "color", "$intent": "Information neutre, aide contextuelle" }
      },
      "background": {
        "page":    { "value": "{primitive.color.gray.1}",      "$type": "color", "$intent": "Fond de page principale" },
        "surface": { "value": "{primitive.color.neutral.0}",   "$type": "color", "$intent": "Fond de carte, panneau, modal" },
        "subtle":  { "value": "{primitive.color.gray.3}",      "$type": "color", "$intent": "Fond secondaire, survol discret" },
        "hover":   { "value": "{primitive.color.neutral.50}",  "$type": "color", "$intent": "Fond au survol (tableaux, listes)" }
      },
      "text": {
        "primary":   { "value": "{primitive.color.gray.12}",     "$type": "color", "$intent": "Texte principal, haute lisibilité" },
        "secondary": { "value": "{primitive.color.gray.11}",     "$type": "color", "$intent": "Texte secondaire, labels, métadonnées" },
        "disabled":  { "value": "{primitive.color.neutral.500}", "$type": "color", "$intent": "Texte désactivé — 4.54:1 sur blanc (WCAG 1.4.3 exempte les UI inactives, maintenu accessible par convention)" },
        "on-action": { "value": "{primitive.color.neutral.0}",   "$type": "color", "$intent": "Texte sur fond d'action (bouton primaire)" },
        "on-danger": { "value": "{primitive.color.neutral.0}",   "$type": "color", "$intent": "Texte sur fond danger" }
      },
      "border": {
        "default": { "value": "{primitive.color.gray.4}",    "$type": "color", "$intent": "Bordure standard" },
        "focus":   { "value": "{primitive.color.blue.11}",   "$type": "color", "$intent": "Bordure focus — accessibilité clavier" },
        "danger":  { "value": "{primitive.color.red.11}",    "$type": "color", "$intent": "Bordure état erreur" }
      }
    },
    "space": {
      "control": {
        "padding-x": { "value": "{space.4}", "$type": "dimension", "$intent": "Espacement horizontal des contrôles interactifs" },
        "padding-y": { "value": "{space.2}", "$type": "dimension", "$intent": "Espacement vertical des contrôles interactifs" },
        "gap":       { "value": "{space.2}", "$type": "dimension", "$intent": "Écart interne entre éléments d'un contrôle" }
      },
      "layout": {
        "section":   { "value": "{space.8}", "$type": "dimension", "$intent": "Espacement entre sections de page" },
        "component": { "value": "{space.5}", "$type": "dimension", "$intent": "Espacement entre composants" }
      }
    },
    "radius": {
      "control": { "value": "{radius.sm}", "$type": "dimension", "$intent": "Rayon pour contrôles interactifs (boutons, inputs)" },
      "card":    { "value": "{radius.md}", "$type": "dimension", "$intent": "Rayon pour conteneurs (cartes, panneaux)" }
    },
    "typography": {
      "body": {
        "size":        { "value": "{fontSize.md}",      "$type": "dimension" },
        "weight":      { "value": "{fontWeight.regular}","$type": "fontWeight" },
        "line-height": { "value": "{lineHeight.normal}", "$type": "number" }
      },
      "label": {
        "size":        { "value": "{fontSize.sm}",      "$type": "dimension" },
        "weight":      { "value": "{fontWeight.medium}", "$type": "fontWeight" },
        "line-height": { "value": "{lineHeight.tight}",  "$type": "number" }
      },
      "heading": {
        "size":        { "value": "{fontSize.xl}",       "$type": "dimension" },
        "weight":      { "value": "{fontWeight.bold}",   "$type": "fontWeight" },
        "line-height": { "value": "{lineHeight.tight}",  "$type": "number" }
      }
    }
  }
}
