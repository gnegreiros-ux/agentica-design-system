    "color": {
      "action": {
        "primary": {
          "$value": "{primitive.color.teal.11}",
          "$type": "color",
          "$intent": "Action principale — CTA, bouton primaire. Teal interactif accessible : en texte sur le fond de page gray.1 #fcfcfc = 5.14:1 ; texte blanc dessus = 5.27:1 (WCAG AA). Distinct du teal d'identité brand.primary (teal.9). Voir ADR-050 (corrige ADR-048)."
        },
        "primary-hover": {
          "$value": "{primitive.color.teal.12}",
          "$type": "color",
