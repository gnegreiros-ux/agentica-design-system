  "primitive": {
    "color-dark": {
      "_readme": {
        "$value": "Radix UI Color System — Dark mode primitives (stock @radix-ui/colors v3.0.0, unmodified)",
        "$type": "other",
        "$description": "Dark-theme counterpart to primitives.json's color.* scales, for the Radix palettes actually referenced in semantic.json (gray, mauve, slate, blue, crimson, green, orange, red, teal). These are the OFFICIAL Radix dark values, taken as-is from the @radix-ui/colors package (ADR-085) — not yet wired into any build target. Deliberately namespaced as color-dark (not color) to avoid a silent token-path collision with primitives.json's light scales if ever added to the same Style Dictionary source list. semantic.dark.json independently carries its own already-calibrated dark values (some deliberately adjusted from stock Radix for WCAG contrast, e.g. action.primary/teal — see ADR-048, ADR-050) and does not consume this file. Custom brand scales (accent, secondary) have no Radix dark equivalent by definition — they stay hand-tuned in semantic.dark.json."
      },
