{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "description": "Composite tokens for Tokens Studio — generation of Figma Text Styles. Not processed by Style Dictionary."
  },
  "typography": {
    "detail": {
      "$value": {
        "fontFamily": "Atkinson Hyperlegible",
        "fontWeight": "Regular",
        "fontSize": "12",
        "lineHeight": "160%",
        "letterSpacing": "0%",
        "textCase": "none",
        "textDecoration": "none"
      },
      "$type": "typography",
      "$description": "12px · Regular · 1.6 — Annotations, captions, aide contextuelle"
    },
    "detail-bold": {
      "$value": {
        "fontFamily": "Atkinson Hyperlegible",
        "fontWeight": "Bold",
        "fontSize": "12",
        "lineHeight": "160%",
        "letterSpacing": "0%",
        "textCase": "none",
        "textDecoration": "none"
      },
      "$type": "typography",
      "$description": "12px · Bold · 1.6 — Emphasis on an annotation (section eyebrow, badge). Generates the Figma Text Style \"typography/detail-bold\"."
    },
    "label": {
      "$value": {
        "fontFamily": "Atkinson Hyperlegible",
        "fontWeight": "Regular",
