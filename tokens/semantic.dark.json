{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "level": "semantic",
    "description": "Dark mode overrides — tokens whose value changes under [data-theme='dark']. Contains ONLY the deltas vs. semantic.json (light mode). Reference source: site/build.js :root[data-theme='dark']. See ADR-065."
  },
  "semantic": {
    "color": {
      "action": {
        "primary": {
          "$value": "#34d3bb",
          "$type": "color",
          "$intent": "Action principale dark — teal clair accessible sur fond sombre (≥4.5:1)"
        },
        "primary-hover": {
          "$value": "#5fe0cd",
          "$type": "color",
          "$intent": "Survol action principale dark"
        },
        "primary-disabled": {
          "$value": "#33373d",
          "$type": "color",
          "$intent": "Disabled action, dark — WCAG 1.4.3 exempts inactive states"
        }
      },
      "feedback": {
        "danger": {
          "$value": "#ff9592",
          "$type": "color",
          "$intent": "Danger dark — rouge clair accessible sur fond sombre"
        },
        "danger-subtle": {
          "$value": "#291415",
          "$type": "color",
          "$intent": "Fond subtil danger dark"
        },
        "success": {
          "$value": "#3dd68c",
          "$type": "color",
          "$intent": "Success, dark — accessible light green"
        },
        "success-subtle": {
          "$value": "#132d21",
          "$type": "color",
          "$intent": "Subtle success background, dark"
        },
        "info": {
          "$value": "#34d3bb",
          "$type": "color",
          "$intent": "Info, dark — light teal (same hue as action.primary dark)"
        },
        "info-subtle": {
          "$value": "#0f2925",
          "$type": "color",
          "$intent": "Fond subtil info dark"
        },
        "info-border": {
          "$value": "#1e5e57",
          "$type": "color",
          "$intent": "Bordure info dark"
        },
        "info-text": {
          "$value": "#34d3bb",
          "$type": "color",
          "$intent": "Texte info dark — lisible sur fond info-subtle"
        },
        "warning": {
          "$value": "#ffca16",
          "$type": "color",
          "$intent": "Avertissement dark — jaune lumineux accessible sur fond sombre"
        },
        "warning-subtle": {
          "$value": "#241800",
          "$type": "color",
          "$intent": "Fond subtil avertissement dark"
        },
        "warning-text": {
          "$value": "#ffca16",
          "$type": "color",
          "$intent": "Texte avertissement dark — lisible sur fond warning-subtle"
        }
      },
      "brand": {
        "primary": {
          "$value": "#34d3bb",
          "$type": "color",
          "$intent": "Primary brand, dark — light teal identity"
        },
        "primary-subtle": {
          "$value": "#0d2924",
          "$type": "color",
          "$intent": "Fond subtil marque primaire dark"
        },
        "primary-text": {
          "$value": "#34d3bb",
          "$type": "color",
          "$intent": "Texte marque primaire dark — sur fond subtle"
        },
        "accent-subtle": {
          "$value": "#2a1520",
          "$type": "color",
          "$intent": "Fond subtil accent dark"
        },
        "accent-text": {
          "$value": "#ed6b86",
          "$type": "color",
          "$intent": "Texte accent dark"
        },
        "secondary": {
          "$value": "#6b4b56",
          "$type": "color",
          "$intent": "Secondary brand color, dark"
        },
        "secondary-text": {
          "$value": "#edd9df",
          "$type": "color",
          "$intent": "Secondary brand text, dark"
        }
      },
      "background": {
        "page": {
          "$value": "#0a0c11",
          "$type": "color",
          "$intent": "Page background, dark — the darkest base"
        },
        "surface": {
          "$value": "#13161d",
          "$type": "color",
          "$intent": "Raised surface, dark — cards, panels"
        },
        "subtle": {
          "$value": "#1b1f27",
          "$type": "color",
          "$intent": "Subtle background, dark — recessed sections, table zebra striping"
        },
        "hover": {
          "$value": "#232833",
          "$type": "color",
          "$intent": "Fond survol dark — retour interactif"
        },
        "inverse": {
          "$value": "#120c0f",
          "$type": "color",
          "$intent": "Inverse surface, dark — footer, accent sections"
        }
      },
      "text": {
        "primary": {
          "$value": "#edeef0",
          "$type": "color",
          "$intent": "Texte principal dark — quasi-blanc, fort contraste sur fond page (≥12:1)"
        },
        "secondary": {
          "$value": "#a4abb8",
          "$type": "color",
          "$intent": "Texte secondaire dark — gris moyen, ≥4.5:1 sur fond page"
        },
        "disabled": {
          "$value": "#6b7280",
          "$type": "color",
          "$intent": "Disabled text, dark — WCAG 1.4.3 exempt"
        },
        "on-action": {
          "$value": "#04201c",
          "$type": "color",
          "$intent": "Text on primary button, dark — very dark green for maximum contrast on light teal"
        },
        "on-dark": {
          "$value": "rgba(255,255,255,0.92)",
          "$type": "color",
          "$intent": "Strong text on a dark surface, dark mode — slightly transparent (0.92 vs. 1.00 in light)"
        },
        "on-dark-muted": {
          "$value": "rgba(255,255,255,0.62)",
          "$type": "color",
          "$intent": "Muted text on a dark surface, dark mode"
        },
        "on-danger": {
          "$value": "#3d0f0f",
          "$type": "color",
          "$intent": "Text on danger background, dark — the danger background is light pink (#ff9592), text must be dark"
        }
      },
      "border": {
        "default": {
          "$value": "#272c36",
          "$type": "color",
          "$intent": "Standard border, dark — separators, field outlines"
        },
        "focus": {
          "$value": "#34d3bb",
          "$type": "color",
          "$intent": "Focus border, dark — light teal for keyboard accessibility"
        },
        "danger": {
          "$value": "#ff9592",
          "$type": "color",
          "$intent": "Bordure erreur dark"
        }
      },
      "illustration": {
        "ink": {
          "$value": "#14121a",
          "$type": "color",
          "$intent": "Dark masses of dark-mode illustrations — contrast anchor"
        }
      }
    }
  }
}
