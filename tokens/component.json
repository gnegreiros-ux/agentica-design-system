{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "level": "component",
    "description": "Executable UI contracts. Encoding of UI and behavioral decisions. The foundation of institutional contracts.",
    "version": "1.0.0",
    "rule": "Any modification requires formal approval (TCR). These tokens are organizational contracts.",
    "_extensions-convention": "The $extensions['com.agentica.usage'] fields are agent-ready metadata (DTCG W3C). Fields: role, doNotUse (cross-variant contraindications), decision (ADR). These fields are ignored by Style Dictionary at compile time — expected behavior. See ADR-052."
  },
  "button": {
    "$metadata": {
      "intent": "Trigger a user action",
      "owner": "design-system-team",
      "contract": "guidelines/components/button.md"
    },
    "font-size": {
      "$value": "{semantic.typography.label-bold.size}",
      "$type": "dimension",
      "$intent": "Label size — shared by every variant"
    },
    "font-weight": {
      "$value": "{semantic.typography.label-bold.weight}",
      "$type": "fontWeight",
      "$intent": "Strong label emphasis — shared by every variant (CTA)"
    },
    "primary": {
      "$description": "Primary action button — maximum 1 per section or form. Never for destructive actions.",
      "$extensions": {
        "com.agentica.usage": {
          "role": "button-primary",
          "doNotUse": "Destructive or irreversible actions — use button.critical. Never two Button[primary] in the same section (broken hierarchy). Never style positive-action buttons (e.g. 'Save') with the danger color.",
          "decision": "ADR-005"
        }
      },
      "background": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.action.primary-hover}",
        "$type": "color"
      },
      "background-disabled": {
        "$value": "{semantic.color.action.primary-disabled}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.text.on-action}",
        "$type": "color"
      },
      "padding-x": {
        "$value": "{semantic.space.control.padding-x}",
        "$type": "dimension"
      },
      "padding-y": {
        "$value": "{semantic.space.control.padding-y}",
        "$type": "dimension"
      },
      "radius": {
        "$value": "{semantic.radius.control}",
        "$type": "dimension"
      }
    },
    "critical": {
      "$description": "Critical/destructive action button — danger red. Requires mandatory confirmation before execution. Never use for reversible actions.",
      "$extensions": {
        "com.agentica.usage": {
          "role": "button-critical",
          "doNotUse": "Normal, non-destructive actions — use button.primary. Never apply to a button with no visible confirmation pattern. Never style critical buttons with button.primary tokens (mixed semantics).",
          "decision": "ADR-005"
        }
      },
      "$metadata": {
        "requires-confirmation": true,
        "prevents-double-click": true,
        "audit-log": true,
        "min-contrast": "4.5:1",
        "rule": "Any irreversible action MUST use this variant. Never use primary for destructive actions."
      },
      "background": {
        "$value": "{semantic.color.feedback.danger}",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.feedback.danger-subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.text.on-danger}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.feedback.danger}",
        "$type": "color"
      }
    },
    "secondary": {
      "background": {
        "$value": "transparent",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.background.subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      }
    },
    "ghost": {
      "background": {
        "$value": "transparent",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.background.subtle}",
        "$type": "color"
      },
      "text": {
