{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "level": "component",
    "description": "Contrats UI exécutables. Encodage des décisions UI et comportementales. Base des contrats institutionnels.",
    "version": "1.0.0",
    "rule": "Toute modification requiert une approbation formelle (TCR). Ces tokens sont des contrats organisationnels."
  },
  "button": {
    "$metadata": {
      "intent": "Déclencher une action utilisateur",
      "owner": "design-system-team",
      "contract": "guidelines/components/button.md"
    },
    "primary": {
      "background":          { "value": "{semantic.color.action.primary}",          "$type": "color" },
      "background-hover":    { "value": "{semantic.color.action.primary-hover}",    "$type": "color" },
      "background-disabled": { "value": "{semantic.color.action.primary-disabled}", "$type": "color" },
      "text":                { "value": "{semantic.color.text.on-action}",          "$type": "color" },
      "padding-x":           { "value": "{semantic.space.control.padding-x}",       "$type": "dimension" },
      "padding-y":           { "value": "{semantic.space.control.padding-y}",       "$type": "dimension" },
      "radius":              { "value": "{semantic.radius.control}",                "$type": "dimension" }
    },
    "critical": {
      "$metadata": {
        "requires-confirmation": true,
        "prevents-double-click": true,
        "audit-log": true,
        "min-contrast": "4.5:1",
        "rule": "Toute action irréversible DOIT utiliser cette variante. Ne jamais utiliser primary pour des actions destructrices."
      },
      "background":       { "value": "{semantic.color.feedback.danger}",        "$type": "color" },
      "background-hover": { "value": "{semantic.color.feedback.danger-subtle}",                         "$type": "color" },
      "text":             { "value": "{semantic.color.text.on-danger}",         "$type": "color" },
      "border":           { "value": "{semantic.color.feedback.danger}",        "$type": "color" }
    },
    "secondary": {
      "background":       { "value": "transparent",                             "$type": "color" },
      "background-hover": { "value": "{semantic.color.background.subtle}",     "$type": "color" },
      "text":             { "value": "{semantic.color.action.primary}",        "$type": "color" },
      "border":           { "value": "{semantic.color.action.primary}",        "$type": "color" }
    },
    "ghost": {
      "background":       { "value": "transparent",                             "$type": "color" },
      "background-hover": { "value": "{semantic.color.background.subtle}",     "$type": "color" },
      "text":             { "value": "{semantic.color.action.primary}",        "$type": "color" },
      "border":           { "value": "transparent",                            "$type": "color" }
    }
  },
  "input": {
    "$metadata": {
      "intent": "Permettre la saisie de données par l'utilisateur",
      "owner": "design-system-team"
    },
    "default": {
      "background":   { "value": "{semantic.color.background.surface}", "$type": "color" },
      "border":       { "value": "{semantic.color.border.default}",     "$type": "color" },
      "border-focus": { "value": "{semantic.color.border.focus}",       "$type": "color" },
      "border-error": { "value": "{semantic.color.border.danger}",      "$type": "color" },
      "text":         { "value": "{semantic.color.text.primary}",       "$type": "color" },
      "placeholder":  { "value": "{semantic.color.text.secondary}",     "$type": "color" },
      "radius":       { "value": "{semantic.radius.control}",           "$type": "dimension" },
      "padding-x":    { "value": "{semantic.space.control.padding-x}",  "$type": "dimension" },
      "padding-y":    { "value": "{semantic.space.control.padding-y}",  "$type": "dimension" }
    }
  },
  "card": {
    "$metadata": {
      "intent": "Regrouper des informations liées dans un conteneur visuel distinct",
      "owner": "design-system-team"
    },
    "default": {
      "background": { "value": "{semantic.color.background.surface}", "$type": "color" },
      "border":     { "value": "{semantic.color.border.default}",     "$type": "color" },
      "radius":     { "value": "{semantic.radius.card}",              "$type": "dimension" },
      "padding":    { "value": "{semantic.space.layout.component}",   "$type": "dimension" }
    }
  }
}
