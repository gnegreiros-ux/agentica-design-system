{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "level": "component",
    "description": "Contrats UI exécutables. Encodage des décisions UI et comportementales. Base des contrats institutionnels.",
    "version": "1.0.0",
    "rule": "Toute modification requiert une approbation formelle (TCR). Ces tokens sont des contrats organisationnels.",
    "_extensions-convention": "Les champs $extensions['com.agentica.usage'] sont des métadonnées agent-ready (DTCG W3C). Champs : role, doNotUse (contre-indications croisées entre variantes), decision (ADR). Ces champs sont ignorés par Style Dictionary à la compilation — comportement attendu. Voir ADR-052."
  },
  "button": {
    "$metadata": {
      "intent": "Déclencher une action utilisateur",
      "owner": "design-system-team",
      "contract": "guidelines/components/button.md"
    },
    "font-size": {
      "$value": "{semantic.typography.label-bold.size}",
      "$type": "dimension",
      "$intent": "Taille du libellé — partagée par toutes les variantes"
    },
    "font-weight": {
      "$value": "{semantic.typography.label-bold.weight}",
      "$type": "fontWeight",
      "$intent": "Emphase forte du libellé — partagée par toutes les variantes (CTA)"
    },
    "primary": {
      "$description": "Bouton d'action principale — maximum 1 par section ou formulaire. Jamais pour actions destructrices.",
      "$extensions": {
        "com.agentica.usage": {
          "role": "button-primary",
          "doNotUse": "Actions destructrices ou irréversibles — utiliser button.critical. Jamais deux Button[primary] dans la même section (hiérarchie cassée). Ne jamais styler des boutons d'action positive (ex: 'Enregistrer') avec la couleur danger.",
          "decision": "ADR-005"
        }
      },
      "background": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.action.primary-hover}",
        "$type": "color"
      },
      "background-disabled": {
        "$value": "{semantic.color.action.primary-disabled}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.text.on-action}",
        "$type": "color"
      },
      "padding-x": {
        "$value": "{semantic.space.control.padding-x}",
        "$type": "dimension"
      },
      "padding-y": {
        "$value": "{semantic.space.control.padding-y}",
        "$type": "dimension"
      },
      "radius": {
        "$value": "{semantic.radius.control}",
        "$type": "dimension"
      }
    },
    "critical": {
      "$description": "Bouton d'action critique/destructrice — rouge danger. Requiert une confirmation obligatoire avant exécution. Ne jamais utiliser pour des actions réversibles.",
      "$extensions": {
        "com.agentica.usage": {
          "role": "button-critical",
          "doNotUse": "Actions normales non-destructrices — utiliser button.primary. Ne jamais appliquer à un bouton sans pattern de confirmation affiché. Ne jamais styler des boutons critiques avec les tokens button.primary (mélange de sémantiques).",
          "decision": "ADR-005"
        }
      },
      "$metadata": {
        "requires-confirmation": true,
        "prevents-double-click": true,
        "audit-log": true,
        "min-contrast": "4.5:1",
        "rule": "Toute action irréversible DOIT utiliser cette variante. Ne jamais utiliser primary pour des actions destructrices."
      },
      "background": {
        "$value": "{semantic.color.feedback.danger}",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.feedback.danger-subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.text.on-danger}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.feedback.danger}",
        "$type": "color"
      }
    },
    "secondary": {
      "background": {
        "$value": "transparent",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.background.subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      }
    },
    "ghost": {
      "background": {
        "$value": "transparent",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.background.subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "border": {
        "$value": "transparent",
        "$type": "color"
      }
    }
  },
