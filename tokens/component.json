  "tabs": {
    "$metadata": {
      "intent": "In-page tabbed navigation with an associated panel",
      "owner": "design-system-team",
      "contract": "guidelines/components/tabs.md"
    },
    "default": {
      "tab-text": {
        "$value": "{semantic.color.text.secondary}",
        "$type": "color"
      },
      "tab-text-hover": {
        "$value": "{semantic.color.text.primary}",
        "$type": "color"
      },
      "tab-text-active": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "indicator": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.border.default}",
        "$type": "color"
      },
      "border-focus": {
        "$value": "{semantic.color.border.focus}",
        "$type": "color"
      },
      "padding-x": {
        "$value": "{semantic.space.control.padding-x}",
        "$type": "dimension"
      },
      "padding-y": {
        "$value": "{semantic.space.control.padding-y}",
        "$type": "dimension"
      }
    }
  },
  "top-nav": {
    "$metadata": {
      "intent": "Main horizontal navigation — full-height visual tab pattern, inter-page links. Visually similar to tabs but semantically role=navigation + aria-current=page.",
      "owner": "design-system-team",
      "contract": "guidelines/components/top-nav.md"
    },
    "tab": {
      "color": {
        "$value": "{semantic.color.text.secondary}",
        "$type": "color",
        "$intent": "Navigation link color at rest"
      },
      "color-hover": {
        "$value": "{semantic.color.text.primary}",
        "$type": "color",
        "$intent": "Hover color — reinforcement with no pill background"
      },
      "background-hover": {
        "$value": "{semantic.color.background.subtle}",
        "$type": "color",
        "$intent": "Hover background — zone feedback, not a button effect"
      },
      "color-active": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color",
        "$intent": "Color of the link matching the current page (aria-current=page)"
      },
      "indicator-color": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color",
        "$intent": "Color of the active page's bottom-border indicator"
      },
      "indicator-width": {
        "$value": "2px",
        "$type": "dimension",
        "$intent": "Indicator thickness — positioned at the bottom of the full-height header"
      },
      "padding-x": {
        "$value": "14px",
        "$type": "dimension",
        "$intent": "Horizontal spacing of links — comfortable click zone (different from the standard control-padding-x)"
      },
      "font-size": {
        "$value": "{semantic.typography.label.size}",
        "$type": "dimension",
        "$intent": "Body size of navigation links"
      },
      "font-weight": {
        "$value": "{semantic.typography.label.weight}",
        "$type": "fontWeight",
        "$intent": "Default weight of links"
      },
      "font-weight-active": {
        "$value": "{semantic.typography.label-bold.weight}",
        "$type": "fontWeight",
        "$intent": "Weight of the active page — reinforces readability with no filled background"
      },
      "focus-ring": {
        "$value": "{semantic.color.border.focus}",
        "$type": "color",
        "$intent": "Keyboard focus ring color (WCAG 2.4.7)"
      }
    },
    "cta": {
      "gap": {
        "$value": "8px",
        "$type": "dimension",
        "$intent": "Visual separation between the nav tabs and the adoption CTA button"
      },
      "background": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color",
        "$intent": "CTA button background — stays a button, distinct from the tab pattern"
      },
      "background-hover": {
        "$value": "{semantic.color.action.primary-hover}",
        "$type": "color",
        "$intent": "CTA button background on hover"
      },
      "color": {
        "$value": "{semantic.color.text.on-action}",
        "$type": "color",
        "$intent": "CTA button text on the action-primary background"
      },
      "padding-x": {
        "$value": "{semantic.space.control.padding-x}",
        "$type": "dimension",
        "$intent": "CTA horizontal spacing — aligned with the control standard"
      },
      "padding-y": {
        "$value": "{semantic.space.control.padding-y}",
        "$type": "dimension",
        "$intent": "CTA vertical spacing"
      },
      "radius": {
        "$value": "{semantic.radius.control}",
        "$type": "dimension",
        "$intent": "CTA corner radius — marks its nature as a button vs. the flat tabs"
      }
    }
  }
}
