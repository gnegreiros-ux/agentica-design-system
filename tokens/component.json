          "$value": "{semantic.typography.label.size}",
          "$type": "dimension",
          "$intent": "14px — Titre de carte en contexte Produit SaaS"
        },
        "weight": {
          "$value": "{primitive.fontWeight.bold}",
          "$type": "fontWeight",
          "$intent": "Bold pour distinguer visuellement le titre"
        },
        "line-height": {
          "$value": "{primitive.lineHeight.reading}",
          "$type": "number"
        }
      },
      "body": {
        "size": {
          "$value": "{semantic.typography.label.size}",
          "$type": "dimension",
          "$intent": "14px — Corps de carte en contexte Produit SaaS"
