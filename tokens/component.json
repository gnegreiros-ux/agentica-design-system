{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "level": "component",
    "description": "Contrats UI exécutables. Encodage des décisions UI et comportementales. Base des contrats institutionnels.",
    "version": "1.0.0",
    "rule": "Toute modification requiert une approbation formelle (TCR). Ces tokens sont des contrats organisationnels."
  },
  "button": {
    "$metadata": {
      "intent": "Déclencher une action utilisateur",
      "owner": "design-system-team",
      "contract": "guidelines/components/button.md"
    },
    "primary": {
      "background": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.action.primary-hover}",
        "$type": "color"
      },
      "background-disabled": {
        "$value": "{semantic.color.action.primary-disabled}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.text.on-action}",
        "$type": "color"
      },
      "padding-x": {
        "$value": "{semantic.space.control.padding-x}",
        "$type": "dimension"
      },
      "padding-y": {
        "$value": "{semantic.space.control.padding-y}",
        "$type": "dimension"
      },
      "radius": {
        "$value": "{semantic.radius.control}",
        "$type": "dimension"
      }
    },
    "critical": {
      "$metadata": {
        "requires-confirmation": true,
        "prevents-double-click": true,
        "audit-log": true,
        "min-contrast": "4.5:1",
        "rule": "Toute action irréversible DOIT utiliser cette variante. Ne jamais utiliser primary pour des actions destructrices."
      },
      "background": {
        "$value": "{semantic.color.feedback.danger}",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.feedback.danger-subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.text.on-danger}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.feedback.danger}",
        "$type": "color"
      }
    },
    "secondary": {
      "background": {
        "$value": "transparent",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.background.subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      }
    },
    "ghost": {
      "background": {
        "$value": "transparent",
        "$type": "color"
      },
      "background-hover": {
        "$value": "{semantic.color.background.subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "border": {
        "$value": "transparent",
        "$type": "color"
      }
    }
  },
  "input": {
    "$metadata": {
      "intent": "Permettre la saisie de données par l'utilisateur",
      "owner": "design-system-team"
    },
    "default": {
      "background": {
        "$value": "{semantic.color.background.surface}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.border.default}",
        "$type": "color"
      },
      "border-focus": {
        "$value": "{semantic.color.border.focus}",
        "$type": "color"
      },
      "border-error": {
        "$value": "{semantic.color.border.danger}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.text.primary}",
        "$type": "color"
      },
      "placeholder": {
        "$value": "{semantic.color.text.secondary}",
        "$type": "color"
      },
      "radius": {
        "$value": "{semantic.radius.control}",
        "$type": "dimension"
      },
      "padding-x": {
        "$value": "{semantic.space.control.padding-x}",
        "$type": "dimension"
      },
      "padding-y": {
        "$value": "{semantic.space.control.padding-y}",
        "$type": "dimension"
      }
    }
  },
  "badge": {
    "$metadata": {
      "intent": "Indiquer un statut, une catégorie ou un compteur.",
      "owner": "design-system-team"
    },
    "neutral": {
      "background": {
        "$value": "{semantic.color.background.subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.text.secondary}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.border.default}",
        "$type": "color"
      }
    },
    "brand": {
      "background": {
        "$value": "{semantic.color.brand.primary-subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{primitive.color.teal.12}",
        "$type": "color"
      },
      "border": {
        "$value": "transparent",
        "$type": "color"
      }
    },
    "success": {
      "background": {
        "$value": "{primitive.color.green.3}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.feedback.success}",
        "$type": "color"
      },
      "border": {
        "$value": "transparent",
        "$type": "color"
      }
    },
    "warning": {
      "background": {
        "$value": "{primitive.color.orange.3}",
        "$type": "color"
      },
      "text": {
        "$value": "{primitive.color.orange.12}",
        "$type": "color"
      },
      "border": {
        "$value": "transparent",
        "$type": "color"
      }
    },
    "danger": {
      "background": {
        "$value": "{semantic.color.feedback.danger-subtle}",
        "$type": "color"
      },
      "text": {
        "$value": "{semantic.color.feedback.danger}",
        "$type": "color"
      },
      "border": {
        "$value": "transparent",
        "$type": "color"
      }
    },
    "info": {
      "background": {
        "$value": "{primitive.color.blue.3}",
        "$type": "color"
      },
      "text": {
        "$value": "{primitive.color.blue.12}",
        "$type": "color"
      },
      "border": {
        "$value": "transparent",
        "$type": "color"
      }
    },
    "md": {
      "radius": {
        "$value": "9999px",
        "$type": "dimension"
      },
      "padding-x": {
        "$value": "{primitive.space.3}",
        "$type": "dimension"
      },
      "padding-y": {
        "$value": "{primitive.space.1}",
        "$type": "dimension"
      },
      "font-size": {
        "$value": "{semantic.typography.label.size}",
        "$type": "dimension"
      }
    },
    "sm": {
      "radius": {
        "$value": "9999px",
        "$type": "dimension"
      },
      "padding-x": {
        "$value": "{primitive.space.2}",
        "$type": "dimension"
      },
      "padding-y": {
        "$value": "2px",
        "$type": "dimension"
      },
      "font-size": {
        "$value": "{semantic.typography.detail.size}",
        "$type": "dimension"
      }
    }
  },
  "card": {
    "$metadata": {
      "intent": "Regrouper des informations liées dans un conteneur visuel distinct",
      "owner": "design-system-team"
    },
    "default": {
      "background": {
        "$value": "{semantic.color.background.surface}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.border.default}",
        "$type": "color"
      },
      "radius": {
        "$value": "{semantic.radius.card}",
        "$type": "dimension"
      },
      "padding": {
        "$value": "{semantic.space.layout.component}",
        "$type": "dimension"
      }
    },
    "elevated": {
      "background": {
        "$value": "{semantic.color.background.surface}",
        "$type": "color"
      },
      "border": {
        "$value": "transparent",
        "$type": "color"
      },
      "shadow": {
        "$value": "{semantic.shadow.card}",
        "$type": "other"
      }
    },
    "flat": {
      "background": {
        "$value": "{semantic.color.background.subtle}",
        "$type": "color"
      },
      "border": {
        "$value": "transparent",
        "$type": "color"
      }
    },
    "padding-none": {
      "$value": "0px",
      "$type": "dimension"
    },
    "padding-sm": {
      "$value": "{primitive.space.3}",
      "$type": "dimension"
    },
    "padding-lg": {
      "$value": "{primitive.space.6}",
      "$type": "dimension"
    }
  },
  "checkbox": {
    "$metadata": {
      "intent": "Sélection binaire indépendante — cocher/décocher une option ou marquer une tâche faite",
      "owner": "design-system-team"
    },
    "default": {
      "background": {
        "$value": "{semantic.color.background.surface}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.border.default}",
        "$type": "color"
      },
      "border-hover": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "border-focus": {
        "$value": "{semantic.color.border.focus}",
        "$type": "color"
      },
      "fill": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "fill-hover": {
        "$value": "{semantic.color.action.primary-hover}",
        "$type": "color"
      },
      "check": {
        "$value": "{semantic.color.text.on-action}",
        "$type": "color"
      },
      "label": {
        "$value": "{semantic.color.text.primary}",
        "$type": "color"
      },
      "radius": {
        "$value": "{semantic.radius.control}",
        "$type": "dimension"
      }
    }
  },
  "radio": {
    "$metadata": {
      "intent": "Sélection mutuellement exclusive — exactement un choix dans un groupe",
      "owner": "design-system-team"
    },
    "default": {
      "background": {
        "$value": "{semantic.color.background.surface}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.border.default}",
        "$type": "color"
      },
      "border-hover": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "border-focus": {
        "$value": "{semantic.color.border.focus}",
        "$type": "color"
      },
      "fill": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "fill-hover": {
        "$value": "{semantic.color.action.primary-hover}",
        "$type": "color"
      },
      "label": {
        "$value": "{semantic.color.text.primary}",
        "$type": "color"
      }
    }
  },
  "toggle": {
    "$metadata": {
      "intent": "Réglage binaire à effet immédiat (on/off) — préférer à la checkbox quand le changement s'applique instantanément",
      "owner": "design-system-team"
    },
    "default": {
      "track-off": {
        "$value": "{primitive.color.gray.9}",
        "$type": "color"
      },
      "track-off-hover": {
        "$value": "{primitive.color.gray.10}",
        "$type": "color"
      },
      "track-on": {
        "$value": "{semantic.color.action.primary}",
        "$type": "color"
      },
      "track-on-hover": {
        "$value": "{semantic.color.action.primary-hover}",
        "$type": "color"
      },
      "knob": {
        "$value": "{semantic.color.background.surface}",
        "$type": "color"
      },
      "border-focus": {
        "$value": "{semantic.color.border.focus}",
        "$type": "color"
      },
      "label": {
        "$value": "{semantic.color.text.primary}",
        "$type": "color"
      }
    }
  },
  "table": {
    "$metadata": {
      "intent": "Présenter des données tabulaires de façon lisible, scannable et accessible — lecture seule",
      "owner": "design-system-team"
    },
    "default": {
