          "$value": "{semantic.typography.heading.4.weight}",
          "$type": "fontWeight",
          "$intent": "Bold to visually distinguish the title"
        },
        "line-height": {
          "$value": "{semantic.typography.label-bold.line-height}",
          "$type": "number"
        }
      },
      "body": {
        "size": {
          "$value": "{semantic.typography.label.size}",
          "$type": "dimension",
          "$intent": "14px — Card body in Product SaaS context"
        },
        "weight": {
          "$value": "{semantic.typography.label.weight}",
          "$type": "fontWeight"
        },
