        "$value": "{semantic.color.background.subtle}",
        "$type": "color"
      },
      "header-text": {
        "$value": "{semantic.color.text.secondary}",
        "$type": "color"
      },
      "cell-text": {
        "$value": "{semantic.color.text.primary}",
        "$type": "color"
      },
      "border": {
        "$value": "{semantic.color.border.default}",
        "$type": "color"
      },
      "row-hover": {
        "$value": "{semantic.color.background.hover}",
        "$type": "color"
      },
      "stripe": {
        "$value": "{semantic.color.background.subtle}",
        "$type": "color"
      },
      "caption-text": {
        "$value": "{semantic.color.text.secondary}",
        "$type": "color"
      },
      "radius": {
        "$value": "{semantic.radius.card}",
        "$type": "dimension"
      },
      "font-size": {
        "$value": "{semantic.typography.label.size}",
        "$type": "dimension"
      }
    },
    "padding-x": {
      "$value": "{primitive.space.3}",
      "$type": "dimension"
    },
    "padding-y-compact": {
      "$value": "{primitive.space.2}",
      "$type": "dimension"
    },
    "padding-y-comfortable": {
      "$value": "{primitive.space.3}",
      "$type": "dimension"
    }
  },
  "link": {
    "$metadata": {
      "intent": "Lien de navigation textuel — inline ou standalone, interne ou externe",
      "owner": "design-system-team"
